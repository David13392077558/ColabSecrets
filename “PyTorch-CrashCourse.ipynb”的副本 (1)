 labels = labels.to(device)  # 将标签移动到设备\n","\n","        outputs = model(images)  # 使用模型进行预测，得到输出\n","\n","        # 获取预测结果：torch.max(outputs, 1) 返回两个值：\n","        # 第一个是最大值的张量，第二个是最大值所在索引的张量。\n","        # 我们只需要索引，所以使用 _ 忽略第一个返回值。\n","        _, predicted = torch.max(outputs, 1)\n","        n_correct += (predicted == labels).sum().item()  # 统计预测正确的样本数量\n","\n","    acc = n_correct / n_samples  # 计算准确率\n","    print(f'Accuracy of the network on the {n_samples} test images: {100*acc} %')  # 打印准确率"],"metadata":{"id":"HRskreiIfrRN","colab":{"base_uri":"https://localhost:8080/","height":211},"executionInfo":{"status":"error","timestamp":1731502225138,"user_tz":-480,"elapsed":31,"user":{"displayName":"David liang","userId":"16007436119041149643"}},"outputId":"9ef158f8-da14-483d-b744-843ecd5ca367"},"execution_count":7,"outputs":[{"output_type":"error","ename":"RuntimeError","evalue":"shape '[-1, 784]' is invalid for input of size 98304","traceback":["\u001b[0;31m---------------------------------------------------------------------------\u001b[0m","\u001b[0;31mRuntimeError\u001b[0m                              Traceback (most recent call last)","\u001b[0;32m<ipython-input-7-8ac5294fa87b>\u001b[0m in \u001b[0;36m<cell line: 2>\u001b[0;34m()\u001b[0m\n\u001b[1;32m     10\u001b[0m     \u001b[0;31m# 遍历测试数据加载器，获取每个批次的图像和标签\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m     11\u001b[0m     \u001b[0;32mfor\u001b[0m \u001b[0mimages\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0mlabels\u001b[0m \u001b[0;32min\u001b[0m \u001b[0mtest_loader\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m---> 12\u001b[0;31m         \u001b[0mimages\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0mimages\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mreshape\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m-\u001b[0m\u001b[0;36m1\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;36m28\u001b[0m\u001b[0;34m*\u001b[0m\u001b[0;36m28\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;