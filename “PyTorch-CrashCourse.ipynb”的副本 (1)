dden2): Linear(in_features=128, out_features=256, bias=True)\n","  (out): Linear(in_features=256, out_features=10, bias=True)\n",")\n"]}]},{"cell_type":"code","source":["# 全连接神经网络，包含一个隐藏层\n","class NeuralNet(nn.Module):\n","    def __init__(self, input_size, hidden_size, num_classes):\n","        \"\"\"\n","        初始化神经网络。\n","\n","        Args:\n","            input_size: 输入层大小。\n","            hidden_size: 隐藏层大小。\n","            num_classes: 输出层大小，即类别数量。\n","        \"\"\"\n","        super(NeuralNet, self).__init__()\n","        self.l1 = nn.Linear(input_size, hidden_size)  # 定义第一个线性层（输入层到隐藏层）\n","        self.relu = nn.ReLU()  # 定义 ReLU 激活函数\n","        self.l2 = nn.Linear(hidden_size, num_classes)  # 定义第二个线性层（隐藏层到输出层）\n","\n","    def forward(self, x):\n","        \"\"\"\n","        定义神经网络的前向传播过程。\n","\n","        Args:\n","            x: 输入数据。\n","\n","        Returns:\n","            out: 模型的输出。\n","        \"\"\"\n","        out = self.l1(x)  # 将输入数据传递给第一个线性层\n","        out = self.relu(out)  # 应用 ReLU 激活函数\n","        out = self.l2(out)  # 将结果传递给第二个线性层\n","        # 最后没有激活函数和 softmax，因为 CrossEntropyLoss 会处理\n","        return out\n","\n","# 创建模型实例，并将其移动到设备（CPU 或 GPU）\n","model = NeuralNet(input_size, hidden_size, num_classes).to(device)\n","\n","# 定义损失函数和优化器\n","criterion = nn.CrossEntropyLoss()  # 使用交叉熵损失函数\n","optimizer = torch.optim.Adam(model.parameters(), lr=learning_rate)  # 使用 Adam 优化器\n","\n","# 训练模型\n","n_total_steps = len(train_loader)  # 获取训练数据加载器的长度，即批次数量\n","for epoch in range(num_epochs):  # 遍历训练轮数\n","    for i, (images, labels) in enumerate(train_loader):  # 遍历每个批次的数据\n","        # 原始形状: [batch_size, 1, 28, 28]\n","        # 调整大小: [batch_size, 784]\n","        images = images.reshape(-1, 28*28).to(device)  # 将图像展平并移动到设备\n","        labels = labels.to(device)  # 将标签移动到设备\n","\n","        # 下面将进行前向传播、损失计算、反向传播和参数更新\n","        # ..."],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":211},"id":"mMpQoODIgGTZ","executionInfo":{